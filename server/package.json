{
  "name": "door-server",
  "version": "1.0.0",
  "description": "DOOR 工具门户后端服务",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "worker": "node src/worker.js",
    "worker:dev": "node --watch src/worker.js",
    "migrate": "npx knex migrate:latest --knexfile src/db/knex.js",
    "migrate:make": "npx knex migrate:make --knexfile src/db/knex.js",
    "test": "node --test 'tests/**/*.test.js'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "uuid": "^9.0.1"
  }
}