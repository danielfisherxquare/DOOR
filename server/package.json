{
  "name": "door-server",
  "version": "1.0.0",
  "description": "DOOR 工具门户后端服务",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "dev": "node --env-file=.env --watch src/index.js",
    "worker": "node --env-file=.env src/worker.js",
    "worker:dev": "node --env-file=.env --watch src/worker.js",
    "migrate": "npx knex migrate:latest --knexfile knexfile.js",
    "migrate:make": "npx knex migrate:make --knexfile knexfile.js",
    "test": "node --env-file=.env --test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "pg": "^8.13.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}
