POSTGRES_PASSWORD=your_secure_password
JWT_SECRET=your_jwt_secret
NODE_ENV=production
PORT=3001
PUBLIC_BASE_URL=http://47.251.107.41:8080

# Comma-separated allowed origins in production (no 80/443 on this server)
# Example: http://47.251.107.41:8080,http://www.xquareliu.com:8080
CORS_ORIGIN=http://47.251.107.41:8080,http://www.xquareliu.com:8080

# Disable public registration in production
DISABLE_REGISTRATION=true

# Super admin seed (run: docker compose exec -e SUPER_ADMIN_PASSWORD=... app node scripts/seed-super-admin.js)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@platform.local
SUPER_ADMIN_PASSWORD=
