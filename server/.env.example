POSTGRES_PASSWORD=your_secure_password
JWT_SECRET=your_jwt_secret
ASSESSMENT_FIELD_ENCRYPTION_KEY=your_assessment_field_encryption_key
ASSESSMENT_SESSION_JWT_SECRET=your_assessment_session_jwt_secret
ASSESSMENT_HASH_PEPPER=your_assessment_hash_pepper
NODE_ENV=production
PORT=3001
PUBLIC_BASE_URL=https://www.xquareliu.com
REDIS_URL=redis://redis:6379

# Comma-separated allowed origins in production
# Example: https://www.xquareliu.com,https://xquareliu.com
CORS_ORIGIN=https://www.xquareliu.com,https://xquareliu.com,http://47.251.107.41

# Disable public registration in production
DISABLE_REGISTRATION=true

# Super admin seed (run: docker compose exec -e SUPER_ADMIN_PASSWORD=... app node scripts/seed-super-admin.js)
SUPER_ADMIN_USERNAME=Xquareliu
SUPER_ADMIN_EMAIL=admin@platform.local
SUPER_ADMIN_PASSWORD=

# DashScope LLM API（马拉松报告生成器）
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
